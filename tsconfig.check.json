{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "paths": {
      "@scribe-atp/core": ["./packages/core/src/index.ts"],
      "@scribe-atp/react": ["./packages/react/src/index.ts"],
      "@scribe-atp/vue": ["./packages/vue/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ]
}
