{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "types": ["@testing-library/jest-dom"],
    "paths": {
      "@scribe-atp/core": ["./packages/core/src/index.ts"],
      "@scribe-atp/react": ["./packages/react/src/index.ts"],
      "@scribe-atp/social": ["./packages/social/src/index.ts"],
      "@scribe-atp/next": ["./packages/next/src/index.ts"],
      "@scribe-atp/vue": ["./packages/vue/src/index.ts"],
      "#app": ["./node_modules/nuxt/dist/app/index.d.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ]
}
