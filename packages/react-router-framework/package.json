{
  "name": "@scribe-atp/react-router-framework",
  "version": "0.1.0",
  "description": "Loader factories for reading Scribe CMS content in React Router v7 framework mode.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@scribe-atp/core": "*"
  },
  "peerDependencies": {
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "react-router": "^7.6.2"
  }
}
